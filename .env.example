# AgentiHooks — Environment Variables
# Copy to .env and customize.

# =============================================================================
# HOOK LOGGING
# =============================================================================
CLAUDE_HOOK_LOG_ENABLED=true
CLAUDE_HOOK_LOG_FILE=/tmp/claude-hooks.log
AGENT_LOG_FILE=/app/logs/agent.log
LOG_HOOKS_COMMANDS=true
LOG_TRANSCRIPT=true
STREAM_AGENT_LOG=true
LOG_USE_COLORS=false

# =============================================================================
# MEMORY
# =============================================================================
MEMORY_AUTO_SAVE=true

# =============================================================================
# REDIS (optional — file fallback if not set)
# =============================================================================
# REDIS_URL=redis://redis:6379/0

# =============================================================================
# MCP TOOL SERVER
# =============================================================================
# MCP_CATEGORIES=all
# ALLOWED_TOOLS=

# =============================================================================
# INTEGRATIONS
# =============================================================================

# GitHub (App-based auth)
# GITHUB_APP_ID=
# GITHUB_INSTALLATION_ID=
# GITHUB_PEM_SECRET_NAME=

# Confluence
# CONFLUENCE_URL=
# CONFLUENCE_TOKEN=
# CONFLUENCE_SPACE=
# CONFLUENCE_USER=

# Email (SMTP)
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_USER=
# EMAIL_PASSWORD=
# EMAIL_FROM=

# AWS (SQS, S3, Lambda, DynamoDB)
# AWS_REGION=us-east-1
# SQS_QUEUE_URL=
# S3_BUCKET=
# LAMBDA_FUNCTION_NAME=

# Webhook
# WEBHOOK_URL=
# WEBHOOK_AUTH_HEADER=
# WEBHOOK_AUTH_VALUE=

# PostgreSQL
# POSTGRES_URL=

# Completions endpoint
# COMPLETIONS_URL=
# COMPLETIONS_AUTH_HEADER=
# COMPLETIONS_AUTH_VALUE=
