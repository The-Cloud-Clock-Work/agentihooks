{
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "model": "sonnet",
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "Task(*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "AGENTIHOOKS_SECRETS_MODE": "strict"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/iamroot/dev/agentihooks && /home/iamroot/dev/antoncore/.venv/bin/python -m hooks"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/iamroot/dev/agentihooks && /home/iamroot/dev/antoncore/.venv/bin/python -m hooks"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/iamroot/dev/agentihooks && /home/iamroot/dev/antoncore/.venv/bin/python -m hooks"
          }
        ]
      }
    ],
